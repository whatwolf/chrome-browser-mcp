{
  "$schema": "https://schema.tauri.app/2.0/tauri.json",
  "productName": "autorunway-tauri-app",
  "version": "1.0.0",
  "identifier": "com.autorunway.app",
  "build": {
    "beforeDevCommand": null,
    "beforeBuildCommand": null,
    "frontendDist": "../"
  },
  "app": {
    "windows": [
      {
        "title": "Autorunway",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}