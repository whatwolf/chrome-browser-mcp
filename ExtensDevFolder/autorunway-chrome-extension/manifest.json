{
  "manifest_version": 3,
  "name": "Autorunway",
  "version": "1.0.0",
  "description": "与Autorunway桌面端应用交互",
  "content_scripts": [
    {
      "matches": [
        "https://app.runwayml.com/video-tools/*"
      ],
      "js": [
        "jquery-3.7.1.min.js",
        "contents.js"
      ],
      "css": [
        "styles.css"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:30008/*",
    "http://127.0.0.1:30008/*",
    "https://*.runwayml.com/*",
    "https://*.cloudfront.net/*"
  ]
}